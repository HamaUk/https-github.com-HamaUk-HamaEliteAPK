<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Theme.MaterialComponents.DayNight.NoActionBar:
        - Works with ALL Material widgets (MaterialCardView, TextInputLayout, etc.)
        - Does NOT require DynamicColors / Google Play Services (TV-safe)
        - Compatible with Android 5.0+ (API 21+)
        - The original DynamicColors crash was because Fire TV doesn't have Google's color engine.
          This theme avoids that entirely.
    -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryVariant">#6200EE</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSecondary">#BB86FC</item>
        <item name="colorSecondaryVariant">#6200EE</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">#1E1E2E</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:colorBackground">#0D0D17</item>
        <item name="colorOnBackground">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.FullScreen" parent="AppTheme.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="VuCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/vu_card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <style name="spinnerTheme">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="MyDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/vu_sidebar_bg</item>
        <item name="colorOnSurface">#FFFFFF</item>
    </style>

</resources>
