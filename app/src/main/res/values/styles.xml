<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- AppCompat-based theme — works on ALL Android versions including Fire TV / Android TV boxes -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryDark">#6200EE</item>
        <item name="colorAccent">#BB86FC</item>
        <item name="android:windowBackground">@color/vu_bg_dark</item>
        <item name="android:colorBackground">@color/vu_bg_dark</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.FullScreen" parent="AppTheme.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="VuCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/vu_card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <style name="spinnerTheme">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="MyDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:background">@color/vu_sidebar_bg</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

</resources>
