<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#221111" />
            <stroke android:width="2dp" android:color="#E53935" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#1E0E0E" />
            <stroke android:width="2dp" android:color="#C62828" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#141414" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
