<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vu_bg_dark"
    tools:context=".MainActivity">

    <!-- Fullscreen Background Image -->
    <ImageView
        android:id="@+id/img_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/background" />

    <!-- Dark Overlay / Vignette -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <!-- Centered Glass Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_login"
        style="@style/VuCard"
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        app:strokeColor="@color/white_opacity_20"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/black_opacity_90"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Logo Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMA"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="UK"
                    android:textColor="@color/vu_purple"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="PREMIUM ACTIVATION"
                android:textColor="@color/vu_purple"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <!-- Tab Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@color/white_opacity_10"
                android:orientation="horizontal"
                android:padding="2dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_sync"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SYNC"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_load"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_xtream"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="XTREAM"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_world"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_m3u"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="M3U URL"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_file"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF" />
            </LinearLayout>

            <!-- Method Specific Sub-groups -->
            <!-- 1. Sync Section -->
            <LinearLayout
                android:id="@+id/layout_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR DEVICE CODE"
                    android:textColor="#FFFFFF"
                    android:alpha="0.6"
                    android:textSize="10sp"
                    android:letterSpacing="0.3" />

                <TextView
                    android:id="@+id/tv_device_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMA-XXXX"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginVertical="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_sync"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="REFRESH SYNC"
                    android:backgroundTint="@color/vu_purple"
                    app:icon="@drawable/ic_load"
                    app:iconPadding="8dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <!-- 2. Xtream Section (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_xtream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">
                
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white_opacity_10">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_server"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Host / URL"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white_opacity_10">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Username"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white_opacity_10">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login_xtream"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOGIN"
                    android:backgroundTint="@color/vu_purple"
                    app:icon="@drawable/ic_world"
                    app:iconPadding="8dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <!-- 3. M3U Section (Hidden by default) -->
             <LinearLayout
                android:id="@+id/layout_m3u"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">
                
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white_opacity_10">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_m3u_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="M3U URL"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login_m3u"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOAD URL"
                    android:backgroundTint="@color/vu_purple"
                    app:icon="@drawable/ic_file"
                    app:iconPadding="8dp"
                    android:layout_marginTop="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#33FFFFFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginEnd="12dp" android:text="OR" android:textColor="#66FFFFFF" android:textSize="11sp" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#33FFFFFF" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pick_file"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OPEN M3U / M3U8 FILE"
                    android:backgroundTint="@android:color/transparent"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_file"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF"
                    app:strokeColor="@color/white_opacity_20"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>