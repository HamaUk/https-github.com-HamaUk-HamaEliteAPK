<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_page_bg"
    tools:context=".MainActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <!-- Centered Glass Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_login"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#E6101010"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:strokeColor="#22FFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Logo Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMA"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="UK"
                    android:textColor="#E53935"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="PREMIUM ACTIVATION"
                android:textColor="#E53935"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.3" />

            <!-- Subtle separator -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:background="#E53935" />

            <!-- Tab Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_tab_container"
                android:orientation="horizontal"
                android:padding="3dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_sync"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="SYNC"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_load"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="#FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_xtream"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="XTREAM"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_world"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="#FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_m3u"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="M3U URL"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_file"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="#FFFFFF" />
            </LinearLayout>

            <!-- 1. Sync Section -->
            <LinearLayout
                android:id="@+id/layout_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR DEVICE CODE"
                    android:textColor="#FFFFFF"
                    android:alpha="0.5"
                    android:textSize="10sp"
                    android:letterSpacing="0.3" />

                <TextView
                    android:id="@+id/tv_device_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMA-XXXX"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginVertical="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_sync"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="REFRESH SYNC"
                    android:textSize="14sp"
                    android:background="@drawable/bg_button_crimson"
                    android:backgroundTint="@null"
                    app:icon="@drawable/ic_load"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- 2. Xtream Section -->
            <LinearLayout
                android:id="@+id/layout_xtream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="#1AFFFFFF"
                    app:boxStrokeColor="#E53935">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_server"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Host / URL"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="#1AFFFFFF"
                    app:boxStrokeColor="#E53935">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Username"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="#1AFFFFFF"
                    app:boxStrokeColor="#E53935">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login_xtream"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="LOGIN"
                    android:textSize="14sp"
                    android:background="@drawable/bg_button_crimson"
                    android:backgroundTint="@null"
                    app:icon="@drawable/ic_world"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <!-- 3. M3U Section -->
            <LinearLayout
                android:id="@+id/layout_m3u"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="#1AFFFFFF"
                    app:boxStrokeColor="#E53935">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_m3u_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="M3U URL"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login_m3u"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="LOAD URL"
                    android:textSize="14sp"
                    android:background="@drawable/bg_button_crimson"
                    android:backgroundTint="@null"
                    app:icon="@drawable/ic_file"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#22FFFFFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:layout_marginEnd="14dp" android:text="OR" android:textColor="#55FFFFFF" android:textSize="11sp" android:letterSpacing="0.1" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#22FFFFFF" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pick_file"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="OPEN M3U / M3U8 FILE"
                    android:textSize="13sp"
                    android:background="@drawable/bg_button_outline"
                    android:backgroundTint="@null"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_file"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF"
                    app:strokeColor="@android:color/transparent"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
