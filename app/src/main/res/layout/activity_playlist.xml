<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_page_bg"
    android:fitsSystemWindows="false"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Header bar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="@drawable/hk_rounded_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <View
            android:layout_width="2dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="12dp"
            android:background="#22FFFFFF" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="پەخشی ڕاستەوخۆ"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <!-- Sort button -->
        <ImageView
            android:id="@+id/btn_sort"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_load"
            app:tint="#BBBBBB"
            android:contentDescription="ڕیزکردن" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/vu_badge_red" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  LOADING OVERLAY (covers content while fetching)  -->
    <!-- ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="#E6080808"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/hk_rounded_bg"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_horizontal">

            <!-- Pulsing live icon -->
            <ImageView
                android:id="@+id/loading_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_live"
                app:tint="#E53935" />

            <!-- Title -->
            <TextView
                android:id="@+id/loading_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="بارکردنی کەناڵەکان"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <!-- Status text -->
            <TextView
                android:id="@+id/loading_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="پەیوەندی بە سێرڤەرەوە..."
                android:textColor="#88FFFFFF"
                android:textSize="13sp" />

            <!-- Progress bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <!-- Background track -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_search_field" />

                <!-- Crimson progress fill -->
                <View
                    android:id="@+id/loading_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:background="#E53935" />
            </FrameLayout>

            <!-- Percentage + channel count row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/loading_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#E53935"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/loading_channel_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#66FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- Sidebar + channel list -->
    <LinearLayout
        android:id="@+id/content_row"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <!-- Category Sidebar -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="230dp"
            android:layout_height="match_parent"
            android:background="@drawable/hk_rounded_bg"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/et_search_categories"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_search_field"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:drawableTint="#66FFFFFF"
                android:hint="@string/hint_search_categories"
                android:importantForAutofill="no"
                android:imeOptions="actionSearch"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#55FFFFFF"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Channel List with search -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_search_channels"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_search_field"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:drawableTint="#66FFFFFF"
                android:hint="گەڕان لە کەناڵەکان..."
                android:importantForAutofill="no"
                android:imeOptions="actionSearch"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#55FFFFFF"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>



