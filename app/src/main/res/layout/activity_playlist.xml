<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vu_bg_dark"
    android:fitsSystemWindows="false">

    <!-- ═══════════════════════════════
         TOP BAR
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher_hama" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <!-- Type badge (injected by code) -->
        <TextView
            android:id="@+id/tv_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/vu_purple"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="LIVE TV"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <!-- Search icon -->
        <ImageView
            android:id="@+id/btn_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_search"
            app:tint="#FFFFFF" />

        <!-- Favorites icon -->
        <ImageView
            android:id="@+id/btn_favorites"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_heart"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- ═══════════════════════════════
         SIDEBAR (Categories)
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="230dp"
        android:layout_height="0dp"
        android:background="@color/vu_sidebar_bg"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <!-- Search box -->
        <EditText
            android:id="@+id/et_search_categories"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/hk_rounded_bg"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="#80FFFFFF"
            android:hint="Search channels..."
            android:paddingStart="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#80FFFFFF"
            android:textSize="13sp"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════
         MAIN CONTENT (Channels)
    ═══════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sidebar"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <TextView
            android:id="@+id/tv_category_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALL CHANNELS"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_category_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
