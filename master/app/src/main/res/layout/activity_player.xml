<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ExoPlayer surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="zoom"
        app:use_controller="false"
        app:surface_type="texture_view" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/player_loading"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="visible" />

    <!-- Error message -->
    <TextView
        android:id="@+id/player_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="پەخشەکە بەردەست نییە"
        android:textColor="#AAFFFFFF"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- Generic center OSD (resize mode, speed, channel number, etc.) -->
    <TextView
        android:id="@+id/resize_osd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="گونجاندن لە شاشە"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:alpha="0"
        android:visibility="invisible" />

    <!-- Channel number input OSD (top center) -->
    <TextView
        android:id="@+id/channel_number_osd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="80dp"
        android:background="#DD000000"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="0"
        android:textColor="#E53935"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:alpha="0"
        android:visibility="invisible" />

    <!-- Volume OSD -->
    <include
        android:id="@+id/volume_osd"
        layout="@layout/overlay_volume_osd"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center|end"
        android:layout_marginEnd="40dp"
        android:alpha="0"
        android:visibility="invisible" />

    <!-- ═══════════════════════════════════════════════ -->
    <!--  TOP INFO BAR                                   -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/player_top_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:background="#C0000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <!-- Channel name -->
        <TextView
            android:id="@+id/tv_current_channel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="کەناڵ"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- EPG info -->
        <TextView
            android:id="@+id/tv_current_epg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="زانیاری نییە"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />

        <!-- Clock -->
        <TextView
            android:id="@+id/tv_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROL BAR                             -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/player_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#C0000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Previous channel -->
        <ImageView
            android:id="@+id/btn_prev_channel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_chevron_left_white"
            android:contentDescription="کەناڵی پێشوو"
            app:tint="#FFFFFF" />

        <!-- Play / Pause -->
        <ImageView
            android:id="@+id/btn_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_pause_white"
            android:contentDescription="پەخش/وەستان"
            app:tint="#FFFFFF" />

        <!-- Next channel -->
        <ImageView
            android:id="@+id/btn_next_channel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_chevron_right_white"
            android:contentDescription="کەناڵی داهاتوو"
            app:tint="#FFFFFF" />

        <!-- Seek bar (hidden for live TV, shown for VOD) -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:progressTint="#BB86FC"
            android:thumbTint="#BB86FC"
            android:visibility="gone" />

        <!-- Spacer when no seekbar -->
        <View
            android:id="@+id/seek_spacer"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:visibility="visible" />

        <!-- Audio track selector -->
        <ImageView
            android:id="@+id/btn_audio_track"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_volume_high"
            android:contentDescription="ڕێچکەی دەنگ"
            app:tint="#BBBBBB" />

        <!-- Subtitle selector -->
        <ImageView
            android:id="@+id/btn_subtitle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_file"
            android:contentDescription="ژێرنووس"
            app:tint="#BBBBBB" />

        <!-- Playback speed -->
        <TextView
            android:id="@+id/btn_speed"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:text="1x"
            android:textColor="#BBBBBB"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Quality selector -->
        <ImageView
            android:id="@+id/btn_quality"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_settings"
            android:contentDescription="کوالێتی"
            app:tint="#BBBBBB" />

        <!-- Resize / fit mode (single control; duplicate fullscreen icon removed) -->
        <ImageView
            android:id="@+id/btn_resize"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:background="@drawable/bg_tv_icon_focus"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:src="@drawable/ic_fullscreen_white"
            android:contentDescription="دۆخی گەورەکردنەوە"
            app:tint="#BBBBBB" />
    </LinearLayout>

</FrameLayout>



