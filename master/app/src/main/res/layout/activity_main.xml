<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Background glow — centered on screen -->
    <View
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:alpha="0.35"
        android:background="@drawable/bg_glow_radial"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_activation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layout_activation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/txt_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rabar_044"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/rabar_044"
                android:gravity="center"
                android:text="@string/activation_status_not_active"
                android:textAlignment="center"
                android:textColor="#FF4B2B"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#22FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/rabar_044"
                android:gravity="center"
                android:text="@string/activation_code_label"
                android:textAlignment="center"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txt_device_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:includeFontPadding="false"
                android:letterSpacing="0.08"
                android:padding="8dp"
                android:text="0000 0000"
                android:textAlignment="center"
                android:textColor="#00D4FF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/rabar_044"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/activation_instructions"
                android:textAlignment="center"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txt_telegram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/rabar_044"
                android:gravity="center"
                android:text="@string/activation_telegram"
                android:textAlignment="center"
                android:textColor="#00D4FF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_premium_btn"
                android:fontFamily="@font/rabar_044"
                android:text="@string/activation_btn_retry"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="28dp"
                app:elevation="8dp" />

            <ProgressBar
                android:id="@+id/progress_sync"
                style="?android:attr/progressBarStyle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:indeterminateTint="#00D4FF"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
