<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardBackgroundColor="@color/sports_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:rippleColor="@color/white_opacity_20"
    app:strokeColor="@color/sports_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:minHeight="112dp"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="14dp">

        <LinearLayout
            android:id="@+id/ll_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_home_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_home_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="Home" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_score_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minWidth="108dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_home_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="28dp"
                    android:gravity="center"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="2"
                    tools:textColor="@color/sports_live_green" />

                <TextView
                    android:id="@+id/tv_score_sep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:alpha="0.5"
                    android:text="–"
                    android:textColor="@color/sports_text_secondary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_away_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="28dp"
                    android:gravity="center"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="1"
                    tools:textColor="@color/sports_live_green" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_match_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_timer_circle"
                android:gravity="center"
                android:minWidth="56dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/sports_live_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="45\'"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_live_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_sports_live_pill"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/sports_status_live"
                android:textAllCaps="true"
                android:textColor="@color/sports_live_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_match_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/sports_text_secondary"
                android:textSize="11sp"
                tools:text="Ended" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_away"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_away_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_away_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="Away" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
