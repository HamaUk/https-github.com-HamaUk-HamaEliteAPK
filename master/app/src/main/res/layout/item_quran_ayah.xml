<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_ayah_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_quran_ayah_normal"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingVertical="20dp">

    <TextView
        android:id="@+id/tv_ayah_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingExtra="12dp"
        android:textAlignment="center"
        android:textColor="?attr/colorOnSurface"
        android:textDirection="rtl"
        android:textSize="26sp"
        android:textStyle="bold"
        tools:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ" />

    <TextView
        android:id="@+id/tv_ayah_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/sports_text_secondary"
        android:textSize="13sp"
        tools:text="Verse 1" />
</LinearLayout>
