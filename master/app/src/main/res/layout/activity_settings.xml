<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_page_bg"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/settings_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/hk_rounded_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="ڕێکخستنەکانی سیستەم"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sidebar Menu -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/hk_rounded_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/settings_header">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_general"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="#FFFFFF"
            android:text="گشتی"
            app:icon="@drawable/ic_settings"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            android:textAlignment="viewStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_player_section"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="#FFFFFF"
            android:text="پەخشکەر"
            app:icon="@drawable/ic_live"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            android:textAlignment="viewStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_content"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="#FFFFFF"
            android:text="ناوەڕۆک"
            app:icon="@drawable/ic_file"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            android:textAlignment="viewStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_account"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="#FFFFFF"
            android:text="هەژمار"
            app:icon="@drawable/ic_heart"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            android:textAlignment="viewStart" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="چوونەدەرەوە"
            android:textColor="#FF5252" />
    </LinearLayout>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/settings_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/hk_rounded_bg"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sidebar"
        app:layout_constraintTop_toBottomOf="@+id/settings_header">

        <!-- General Section -->
        <ScrollView
            android:id="@+id/layout_general"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ڕێکخستنە گشتییەکان"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Default Resize Mode -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="دۆخی گەورەکردنی شاشەی بنەڕەتی"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <RadioGroup
                            android:id="@+id/rg_resize_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_fit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="گونجاندن لە شاشە"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_zoom"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="زووم (100%)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_fill"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="پڕکردنەوەی تەواو"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_fixed_width"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="پانی جێگیر"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Auto-play on start -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="پەخشکردنی خۆکار لە دەستپێک"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_autoplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Player Section -->
        <ScrollView
            android:id="@+id/layout_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ڕێکخستنەکانی پەخشکەر"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Playback engine (Exo vs LibVLC) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="بزوێنەری پەخش"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="پڕۆفایلەکانی جیا: Cinema/Arena هەمان Media3ن بە بۆفەری جیا. Web HLS = Chromium+hls.js (تەنها .m3u8). LibVLC = LGPL."
                            android:textColor="#8890A0"
                            android:textSize="12sp" />
                        <RadioGroup
                            android:id="@+id/rg_player_engine"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_player_exo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="ExoPlayer · Standard (هاوسەنگ)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_exo_cinema"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="ExoPlayer · Cinema (بۆفەری قووڵ، تۆڕی لاواز)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_exo_arena"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="ExoPlayer · Arena (کەمترین دواخستن بۆ live)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_web_hls"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chromium · Web HLS (hls.js)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_vlc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="LibVLC (VLC)"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Buffer Size -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="قەبارەی بۆفەر"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <RadioGroup
                            android:id="@+id/rg_buffer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_buffer_low"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="نزم (دەستپێکی خێراتر، دووبارە بۆفەرکردنی زیاتر)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_buffer_medium"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="ناوەند (هاوسەنگ)"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_buffer_high"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="بەرز (دەستپێکی هێواشتر، پەخشکردنی نەرمتر)"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hardware Acceleration -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="خێراکردنی هاردوێر"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_hw_accel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Content Section -->
        <ScrollView
            android:id="@+id/layout_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بەڕێوەبردنی پلەی لیست"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Active playlist indicator -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="پلەی لیستی چالاک:"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_active_playlist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="بنەڕەت"
                            android:textColor="#E53935"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="پلەی لیستی ئێستا پاشەکەوت بکە وەک..."
                    app:icon="@drawable/ic_heart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_load_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="گۆڕینی پلەی لیست"
                    app:icon="@drawable/ic_load" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E53935"
                    android:text="سڕینەوەی پلەی لیستی پاشەکەوتکراو"
                    app:icon="@drawable/ic_back" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"
                    android:background="#22FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="داتا و کاش"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cache"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="پاککردنەوەی هەموو کاشی بەرنامە"
                    app:icon="@drawable/ic_download" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_data"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="نوێکردنەوەی داتای پلەی لیست"
                    app:icon="@drawable/ic_load" />
            </LinearLayout>
        </ScrollView>

        <!-- Account Section -->
        <ScrollView
            android:id="@+id/layout_account"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="زانیاری ئابوونە"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tv_pkg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="پاکێج: HAMA UK PLAYER"
                            android:textColor="#FFFFFF" />
                        <TextView
                            android:id="@+id/tv_mac"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="ناسنامە: —"
                            android:textColor="#FFFFFF" />
                        <TextView
                            android:id="@+id/tv_expiry"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="دۆخ: چالاک"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>



