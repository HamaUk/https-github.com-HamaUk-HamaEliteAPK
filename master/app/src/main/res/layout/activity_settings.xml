<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_page_bg"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/settings_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/hk_rounded_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/settings_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sidebar Menu -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/sidebar"
        android:layout_width="228dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/hk_rounded_bg"
        android:fillViewport="true"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/settings_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_general"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/settings_general"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_player_section"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/settings_player"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_account"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/settings_account"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_language"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/settings_language"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_appearance"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/settings_appearance"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_last_sync_section"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_last_sync_section"
                android:textAlignment="viewStart"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/settings_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/hk_rounded_bg"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sidebar"
        app:layout_constraintTop_toBottomOf="@+id/settings_header">

        <!-- General Section -->
        <ScrollView
            android:id="@+id/layout_general"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_general_title"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Default Resize Mode -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_resize_mode"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <RadioGroup
                            android:id="@+id/rg_resize_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_fit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_resize_fit"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_zoom"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_resize_zoom"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_fill"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_resize_fill"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_fixed_width"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_resize_fixed"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Auto-play on start -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_autoplay"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_autoplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_stream_resolution"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/settings_stream_hint"
                            android:textColor="#8890A0"
                            android:textSize="12sp" />
                        <RadioGroup
                            android:id="@+id/rg_stream_quality"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_stream_auto"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_stream_auto"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_stream_720"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_stream_720"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_stream_1080"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_stream_1080"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_stream_4k"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_stream_4k"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/settings_playlist_mgmt"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_active_playlist"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_active_playlist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_active_default"
                            android:textColor="#E53935"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="@string/settings_save_playlist" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_load_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="@string/settings_switch_playlist" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete_playlist"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E53935"
                    android:text="@string/settings_delete_playlist" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/settings_data_cache"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cache"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="@string/settings_clear_cache" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_data"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:backgroundTint="@color/vu_purple"
                    android:text="@string/settings_refresh_data" />
            </LinearLayout>
        </ScrollView>

        <!-- Player Section -->
        <ScrollView
            android:id="@+id/layout_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_player_title"
                    android:textColor="@color/vu_purple"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Playback engine (Exo vs LibVLC) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_playback_engine"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/settings_playback_hint"
                            android:textColor="#8890A0"
                            android:textSize="12sp" />
                        <RadioGroup
                            android:id="@+id/rg_player_engine"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_player_exo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_engine_exo"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_exo_cinema"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_engine_cinema"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_player_exo_arena"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_engine_arena"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Buffer Size -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_buffer_size"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <RadioGroup
                            android:id="@+id/rg_buffer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <RadioButton
                                android:id="@+id/rb_buffer_low"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_buffer_low"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_buffer_medium"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_buffer_medium"
                                android:textColor="#B0B0C0" />
                            <RadioButton
                                android:id="@+id/rb_buffer_high"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_buffer_high"
                                android:textColor="#B0B0C0" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hardware Acceleration -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp"
                    style="@style/VuCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_hw_accel"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_hw_accel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Account Section -->
        <ScrollView
            android:id="@+id/layout_account"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_subscription"
                    android:textColor="@color/vu_purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/crimson_glow"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/activation_code_label"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_device_id_display"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:text="0000 0000"
                            android:textColor="#00D4FF"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_device_id"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/settings_copy_device_id"
                            android:textColor="#00D4FF"
                            app:strokeColor="#00D4FF" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView
                            android:id="@+id/tv_pkg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_version"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_expiry"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#B0B0C0"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_account_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/settings_status_premium"
                            android:textColor="#8BC34A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Language Section -->
        <ScrollView
            android:id="@+id/layout_language"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_language_title"
                    android:textColor="@color/vu_purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <RadioGroup
                        android:id="@+id/rg_app_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <RadioButton
                            android:id="@+id/rb_lang_sorani"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language_sorani"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_lang_badini"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language_badini"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_lang_ar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language_arabic"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_lang_en"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language_english"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_lang_system"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language_system"
                            android:textColor="#B0B0C0" />
                    </RadioGroup>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Appearance Section -->
        <ScrollView
            android:id="@+id/layout_appearance"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_appearance_title"
                    android:textColor="@color/vu_purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <RadioGroup
                        android:id="@+id/rg_theme_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <RadioButton
                            android:id="@+id/rb_theme_dark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_dark"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_theme_amoled"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_amoled"
                            android:textColor="#B0B0C0" />
                        <RadioButton
                            android:id="@+id/rb_theme_light"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_light"
                            android:textColor="#B0B0C0" />
                    </RadioGroup>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- Last sync Section -->
        <ScrollView
            android:id="@+id/layout_last_sync"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_last_sync_title"
                    android:textColor="@color/vu_purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <com.google.android.material.card.MaterialCardView
                    style="@style/VuCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/white_opacity_10"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:id="@+id/tv_last_sync_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_last_sync_never"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:lineSpacingExtra="4dp"
                            android:text="@string/settings_last_sync_hint"
                            android:textColor="#8890A0"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
